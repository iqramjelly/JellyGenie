{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "Task",
      "TodoWrite",
      "NotebookEdit",
      "NotebookRead",
      "WebSearch",
      "WebFetch(*)",
      "Skill(*)",
      "mcp__playwright__*"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--cdp-endpoint", "http://127.0.0.1:9222"]
    }
  },
  "skipDangerousModePermissionPrompt": true
}
