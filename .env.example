# ──────────────────────────────────────────────────────────────────────────────
# JELLYGENIE — environment config
# Copy to .env and fill in your own values. Never commit the real .env.
# The setup script (./setup.sh) will walk you through this interactively.
# ──────────────────────────────────────────────────────────────────────────────

# === FIREHOSE (JellyJelly) ===
# Required. Get your JWT from JellyJelly browser DevTools → Application → Cookies.
JELLY_API_URL=https://api.jellyjelly.com/v3
JELLY_AUTH_TOKEN=your-jellyjelly-jwt-here
GENIE_KEYWORD=genie
GENIE_POLL_INTERVAL=3000
GENIE_FAST_RETRY_INTERVAL=1500
GENIE_FAST_RETRY_MAX_MS=300000
GENIE_WATCHED_USERS=

# === TELEGRAM (one-way reporting channel) ===
# Required. Create a bot via @BotFather, get your chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=123456789:your-bot-token-here
TELEGRAM_CHAT_ID=123456789

# === JELLYGENIE IDENTITY ===
# Your display name (used in outreach emails/messages).
JELLYGENIE_OWNER_NAME=
# JellyJelly user UUIDs for the bot accounts (defaults are built-in).
# JELLYGENIE_BOT_USER_ID=
# JELLYGENIE_ALT_USER_ID=

# === DISPATCHER (Claude Code as the execution engine) ===
# Optional overrides. Defaults are fine for most cases.
# GENIE_CLAUDE_BIN=/usr/local/bin/claude
# GENIE_CLAUDE_MODEL=sonnet          # or: opus
# GENIE_MAX_TURNS=200
# GENIE_MAX_BUDGET_USD=25
# GENIE_CLAUDE_TIMEOUT_MS=3600000    # 60 min safety net; set 0 to disable

# === OPENROUTER (free-model fallback) ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# === ANTHROPIC (direct Claude API) ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === DEPLOY (Vercel) ===
# Vercel CLI must be logged in on the host (`vercel login`).
GH_OWNER=your-github-username

# === STRIPE (payment links + invoices via CLI) ===
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_API_KEY=sk_test_your-secret-key

# === GEMINI (optional — vision / grounding) ===
GEMINI_API_KEY=your-gemini-key

# === BROWSER (persistent Chrome via launchd) ===
GENIE_BROWSER_PROFILE=~/.jellygenie/browser-profile
GENIE_CDP_ENDPOINT=http://127.0.0.1:9222
GENIE_HEADED=true

# === Optional integrations ===
# APOLLO_API_KEY=
# RESEND_API_KEY=
